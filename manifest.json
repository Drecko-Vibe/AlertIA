{
  "manifest_version": 3,
  "name": "Alert.ia",
  "description": "Sugestão interna de transferência para assistentes especializados na plataforma Clinicorp.",
  "version": "1.9.0",
  "minimum_chrome_version": "114",
  "permissions": [
    "storage", 
    "activeTab", 
    "scripting", 
    "alarms", 
    "notifications"
  ],
  "host_permissions": [
    "https://servicedesk.clinicorp.tech/*",
    "https://generativelanguage.googleapis.com/*",
    "https://firestore.googleapis.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://servicedesk.clinicorp.tech/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-bridge.js", "sounds/alert.wav", "icons/*.png"],
      "matches": ["https://servicedesk.clinicorp.tech/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}